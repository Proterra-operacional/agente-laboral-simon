    {
      "id": "wf4-router",
      "name": "Router tipo mensaje",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        240,
        304
      ],
      "parameters": {
        "jsCode": "const u = $input.first().json;\nlet tipo='ignorar', chatId='', texto='', callbackData='', callbackQueryId='';\n\nif (u.callback_query) {\n  tipo = 'callback';\n  chatId = String(u.callback_query.from.id);\n  callbackData = u.callback_query.data || '';\n  callbackQueryId = String(u.callback_query.id);\n} else if (u.message?.text) {\n  chatId = String(u.message.chat.id);\n  texto = u.message.text;\n  const t = texto.toLowerCase().trim();\n  if (t === 'confirmar' || t === 'si' || t === 'sí' || t === 'si enviar' || t === 'yes') {\n    tipo = 'confirmar_texto';\n  } else if (t === 'cancelar' || t === 'no') {\n    tipo = 'cancelar_texto';\n  } else if (/^(aplic|regenera|reescribe|mejora|cambia|corrige)/i.test(t) || t.includes('más profesional') || t.includes('mas profesional') || t.includes('aplícalo') || t.includes('aplicalo')) {\n    tipo = 'feedback';\n  } else if (t.includes('correo') || t.includes('email') || t.includes('redacta') || t.includes('escribe un') || t.startsWith('/email')) {\n    tipo = 'nuevo_email';\n  } else {\n    tipo = 'feedback';\n  }\n}\n\nreturn [{ json: { tipo, chatId, texto, callbackData, callbackQueryId } }];"
      }
    },
