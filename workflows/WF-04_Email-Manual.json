    {
      "id": "wf4-claude",
      "name": "OpenRouter Redacta Email",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1300,
        368
      ],
      "parameters": {
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer API_KEY_REDACTED"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: 'llama-3.3-70b-versatile', max_tokens: 1500, messages: [{ role: 'system', content: 'Eres el asistente de Simón Marín Rojas, Ingeniero Comercial y Analista de Procesos y Automatización (contacto@simonmarin.com | +56 9 8401 3356 | Santiago, Chile). Redactas emails profesionales en su nombre para empresas y reclutadores. Tono: formal, directo, sin frases genéricas. Máximo 4 párrafos. Incluye siempre logros cuantificables cuando corresponda. NO incluyas firma, nombre, ni despedida al final del cuerpo. La plantilla HTML agrega la firma automáticamente. CRÍTICO: El cuerpo del email NUNCA debe terminar con firma, nombre, despedida, ni Atentamente. Termina siempre con la última oración del contenido profesional. La firma es agregada automáticamente por el sistema.' + $('Formatear Memoria').first().json.memoryRules }, { role: 'user', content: 'Solicitud de Simón: ' + $('Router tipo mensaje').first().json.texto + '\\n\\nCRÍTICO: NO incluyas firma, nombre, despedida ni Atentamente al final del cuerpo. La plantilla HTML agrega la firma automáticamente.\\n\\nDevuelve SOLO JSON válido sin markdown: {\"toEmail\": \"email@empresa.com\", \"asunto\": \"asunto profesional\", \"cuerpo\": \"texto del correo sin firma ni despedida al final\"}' }] }) }}",
        "options": {}
      }
    },
    {
      "id": "wf4-store-preview",
      "name": "Guardar Draft y Preparar Preview",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1200,
        368
      ],
      "parameters": {
        "jsCode": "const claudeResp = $input.first().json;\nconst chatId = $('Router tipo mensaje').first().json.chatId;\n\nlet toEmail = '', asunto = '', cuerpo = '';\ntry {\n  const content = claudeResp.choices?.[0]?.message?.content || claudeResp.content?.[0]?.text || '';\n  const match = content.match(/\\{[\\s\\S]*\\}/);\n  if (match) {\n    const parsed = JSON.parse(match[0]);\n    toEmail = parsed.toEmail || '';\n    asunto = parsed.asunto || '';\n    cuerpo = parsed.cuerpo || '';\n  }\n} catch(e) {}\n\n// Guardar draft en static data indexado por chatId\nconst sd = $getWorkflowStaticData('global');\nsd['draft_' + chatId] = { toEmail, asunto, cuerpo, ts: Date.now() };\n\nconst previewBody = cuerpo.length > 700 ? cuerpo.substring(0, 700) + '...' : cuerpo;\nconst preview = '📧 *Preview del correo*\\n\\n' +\n  '*Para:* ' + toEmail + '\\n' +\n  '*Asunto:* ' + asunto + '\\n\\n' +\n  '*Cuerpo:*\\n' + previewBody +\n  '\\n\\n——\\n👆 *Usa los botones para confirmar o cancelar*';\n\nreturn [{ json: { chatId, preview, toEmail, asunto, cuerpo } }];"
      }
    },
