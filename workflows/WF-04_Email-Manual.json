        "jsCode": "const chatId = $('Router tipo mensaje').first().json.chatId;\nconst callbackQueryId = $('Router tipo mensaje').first().json.callbackQueryId;\nconst sd = $getWorkflowStaticData('global');\nconst draft = sd['draft_' + chatId] || {};\n\n// Limpiar draft después de leer\ndelete sd['draft_' + chatId];\n\nreturn [{ json: {\n  chatId,\n  callbackQueryId,\n  toEmail: draft.toEmail || '',\n  asunto: draft.asunto || '',\n  cuerpo: draft.cuerpo || '',\n  hasDraft: !!(draft.toEmail)\n} }];"
