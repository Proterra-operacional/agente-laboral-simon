    {
      "id": "wf4-prep-regen",
      "name": "Preparar Regeneración",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1360,
        560
      ],
      "parameters": {
        "jsCode": "const { draft, feedbackText, chatId } = $input.first().json;\n\nconst userPrompt = 'Regenera este email aplicando este cambio: ' + feedbackText + '\\n\\nEmail actual:\\n' +\n  'Para: ' + draft.toEmail + '\\n' +\n  'Asunto: ' + draft.asunto + '\\n' +\n  'Cuerpo: ' + draft.cuerpo + '\\n\\n' +\n  'CRÍTICO: NO incluyas firma, nombre, despedida ni Atentamente al final del cuerpo. La plantilla HTML agrega la firma automáticamente.\\n\\n' +\n  'Devuelve SOLO JSON válido sin markdown: {\"toEmail\": \"email@empresa.com\", \"asunto\": \"asunto profesional\", \"cuerpo\": \"texto del correo sin firma ni despedida al final\"}';\n\nreturn [{ json: { chatId, feedbackText, originalDraft: draft, userPrompt } }];"
      }
    },
    {
      "id": "wf4-groq-regen",
      "name": "Groq Regenera Email",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
