        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: 'llama-3.3-70b-versatile', max_tokens: 1500, messages: [{ role: 'system', content: 'Eres el asistente de Simón Marín Rojas, Ingeniero Comercial y Analista de Procesos y Automatización (contacto@simonmarin.com | +56 9 8401 3356 | Santiago, Chile). Redactas emails profesionales en su nombre para empresas y reclutadores. Tono: formal, directo, sin frases genéricas. Máximo 4 párrafos. CRÍTICO: El cuerpo del email NUNCA debe terminar con firma, nombre, despedida, ni Atentamente. La firma es agregada automáticamente por el sistema.' }, { role: 'user', content: $('Preparar Regeneración').first().json.userPrompt }] }) }}",
        "options": {}
      }
    },
    {
      "id": "wf4-parse-regen",
      "name": "Parsear Email Regenerado",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1760,
        560
      ],
      "parameters": {
        "jsCode": "const resp = $input.first().json;\nconst chatId = $('Preparar Regeneración').first().json.chatId;\nconst feedbackText = $('Preparar Regeneración').first().json.feedbackText;\n\nlet toEmail = '', asunto = '', cuerpo = '';\ntry {\n  const content = resp.choices?.[0]?.message?.content || resp.content?.[0]?.text || '';\n  const match = content.match(/\\{[\\s\\S]*\\}/);\n  if (match) {\n    const parsed = JSON.parse(match[0]);\n    toEmail = parsed.toEmail || '';\n    asunto = parsed.asunto || '';\n    cuerpo = parsed.cuerpo || '';\n  }\n} catch(e) {}\n\nreturn [{ json: { chatId, toEmail, asunto, cuerpo, feedbackText } }];"
      }
    },
    {
      "id": "wf4-save-regen",
      "name": "Guardar Draft Regenerado",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1960,
        560
      ],
      "parameters": {
        "jsCode": "const { chatId, toEmail, asunto, cuerpo } = $input.first().json;\n\nconst sd = $getWorkflowStaticData('global');\nsd['draft_' + chatId] = { toEmail, asunto, cuerpo, ts: Date.now() };\n\nconst previewBody = cuerpo.length > 700 ? cuerpo.substring(0, 700) + '...' : cuerpo;\nconst preview = '✏️ *Correo actualizado:*\\n\\n' +\n  '*Para:* ' + toEmail + '\\n' +\n  '*Asunto:* ' + asunto + '\\n\\n' +\n  '*Cuerpo:*\\n' + previewBody +\n  '\\n\\n——\\n👆 *Usa los botones para confirmar o cancelar*';\n\nreturn [{ json: { chatId, preview, toEmail, asunto, cuerpo } }];"
      }
    },
