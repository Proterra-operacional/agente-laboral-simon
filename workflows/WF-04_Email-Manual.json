      "position": [
        1100,
        368
      ],
      "parameters": {
        "jsCode": "const pages = $input.all();\nif (pages.length === 0 || !pages[0].json.results) return [{ json: { memoryRules: '' } }];\n\nconst rules = pages[0].json.results.map(p => {\n  const nota = p.properties?.Nota?.rich_text?.[0]?.plain_text || '';\n  return nota;\n}).filter(Boolean).join('\\n- ');\n\nreturn [{ json: { memoryRules: rules ? `\\n\\nREGLAS DE MEMORIA:\\n- ${rules}` : '' } }];"
      }
    },
